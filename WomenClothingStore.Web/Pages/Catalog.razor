@page "/catalog"
@using WomenClothingStore.Domain.Entities
@using WomenClothingStore.Domain.Interfaces
@using WomenClothingStore.Web.Services
@inject IProductRepository ProductRepository
@inject ICategoryRepository CategoryRepository
@inject CartService CartService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Каталог — Women's Clothing</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <h3 class="fw-bold text-white mb-0">🛍️ Каталог товаров</h3>
    <span class="badge bg-white text-primary fs-6 px-3 py-2 shadow-sm">
        Найдено: @filteredProducts.Count() шт.
    </span>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-success alert-dismissible shadow-sm border-0 rounded-3 mb-4" role="alert">
        🎉 <strong>@alertMessage</strong> добавлен в корзину!
        <a href="/cart" class="alert-link ms-2">Перейти в корзину →</a>
        <button type="button" class="btn-close" @onclick="() => alertMessage = string.Empty"></button>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-light" role="status" style="width: 3rem; height: 3rem;"></div>
        <p class="mt-3 text-white opacity-75">Загружаем коллекцию...</p>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
                <h6 class="fw-bold text-dark mb-3">📂 Категория</h6>
                <div class="d-flex flex-column gap-2">
                    <button type="button"
                            class="btn @(selectedCategoryId == 0 ? "btn-primary" : "btn-outline-secondary") btn-sm text-start fw-semibold"
                            @onclick="() => SelectCategory(0)">
                        ✨ Все категории
                    </button>
                    @foreach (var cat in categories)
                    {
                        <button type="button"
                                class="btn @(selectedCategoryId == cat.Id ? "btn-primary" : "btn-outline-secondary") btn-sm text-start fw-semibold"
                                @onclick="() => SelectCategory(cat.Id)">
                            @cat.Emoji @cat.Name
                        </button>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
                <h6 class="fw-bold text-dark mb-3">📏 Размер</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var size in allSizes)
                    {
                        var isSelected = selectedSizes.Contains(size);
                        <button type="button"
                                class="btn @(isSelected ? "btn-dark" : "btn-outline-dark") btn-sm fw-bold"
                                style="min-width: 48px;"
                                @onclick="() => ToggleSize(size)">
                            @size
                        </button>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-3">
                <h6 class="fw-bold text-dark mb-3">🔃 Сортировка</h6>
                <select class="form-select form-select-sm border-0 bg-light"
                        @onchange="OnSortChanged">
                    <option value="default">По умолчанию</option>
                    <option value="price_asc">Цена: по возрастанию</option>
                    <option value="price_desc">Цена: по убыванию</option>
                    <option value="rating_desc">Рейтинг: высокий сначала</option>
                </select>

                @if (selectedCategoryId != 0 || selectedSizes.Any() || currentSort != "default")
                {
                    <button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2"
                            @onclick="ResetFilters">
                        ✖ Сбросить фильтры
                    </button>
                }
            </div>
        </div>

        <div class="col-lg-9">
            @if (!filteredProducts.Any())
            {
                <div class="text-center py-5 text-white">
                    <div class="fs-1 mb-3">🔍</div>
                    <h5 class="fw-bold">Товары не найдены</h5>
                    <p class="opacity-75">Попробуйте изменить фильтры</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var product in filteredProducts)
                    {
                        var countInCart = CartService.Items
                        .Where(i => i.Product.Id == product.Id)
                        .Sum(i => i.Quantity);

                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card">

                                @if (countInCart > 0)
                                {
                                    <span class="position-absolute top-0 end-0 badge bg-success m-2 px-2 py-1 shadow z-1">
                                        🛒 @countInCart шт.
                                    </span>
                                }

                                @if (product.Reviews.Any())
                                {
                                    <span class="position-absolute top-0 start-0 badge bg-warning text-dark m-2 px-2 py-1 shadow z-1">
                                        ⭐ @product.AverageRating
                                    </span>
                                }

                                <div style="height: 260px; overflow: hidden; cursor: pointer;"
                                     @onclick="() => GoToProduct(product.Id)">
                                    @if (product.Images.Any())
                                    {
                                        var img = product.Images.FirstOrDefault(i => i.IsMain) ?? product.Images.First();
                                        <img src="@img.Url" alt="@product.Name"
                                             style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;"
                                             class="product-img" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                                            <span class="fs-1">👗</span>
                                        </div>
                                    }
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <p class="text-muted small mb-1">@product.Category?.Name</p>
                                    <h6 class="fw-bold text-dark mb-1" style="cursor: pointer;"
                                        @onclick="() => GoToProduct(product.Id)">
                                        @product.Name
                                    </h6>
                                    <p class="text-muted small mb-2 flex-grow-1"
                                       style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @product.Description
                                    </p>

                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        @foreach (var ps in product.ProductSizes.OrderBy(ps => ps.Size.SortOrder))
                                        {
                                            <span class="badge @(ps.StockQuantity > 0 ? "bg-light text-dark border" : "bg-light text-muted border opacity-50")"
                                                  style="font-size: 0.7rem;">
                                                @ps.Size.Label
                                                @if (ps.StockQuantity == 0)
                                                {
                                                    <text>✖</text>
                                                }
                                            </span>
                                        }
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                                        <span class="fs-5 fw-bold text-dark">@product.Price.ToString("N0") ₽</span>
                                        <button type="button"
                                                class="btn btn-primary btn-sm px-3 rounded-pill"
                                                @onclick="() => GoToProduct(product.Id)">
                                            Подробнее →
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.15) !important;
        }

            .product-card:hover .product-img {
                transform: scale(1.05);
            }
</style>

@code {
    private IEnumerable<Product> allProducts = new List<Product>();
    private IEnumerable<Product> filteredProducts = new List<Product>();
    private IEnumerable<Category> categories = new List<Category>();
    private List<string> allSizes = new();
    private HashSet<string> selectedSizes = new();
    private int selectedCategoryId = 0;
    private string currentSort = "default";
    private string alertMessage = string.Empty;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductRepository.GetProductsWithDetailsAsync();
        categories = await CategoryRepository.GetAllAsync();

        allSizes = allProducts
            .SelectMany(p => p.ProductSizes)
            .Select(ps => ps.Size)
            .DistinctBy(s => s.Id)
            .OrderBy(s => s.SortOrder)
            .Select(s => s.Label)
            .ToList();

        isLoading = false;
        ApplyFilters();
    }

    private void SelectCategory(int id)
    {
        selectedCategoryId = id;
        ApplyFilters();
    }

    private void ToggleSize(string size)
    {
        if (selectedSizes.Contains(size))
            selectedSizes.Remove(size);
        else
            selectedSizes.Add(size);

        ApplyFilters();
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        currentSort = e.Value?.ToString() ?? "default";
        ApplyFilters();
    }

    private void ResetFilters()
    {
        selectedCategoryId = 0;
        selectedSizes.Clear();
        currentSort = "default";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var result = allProducts.AsEnumerable();

        if (selectedCategoryId != 0)
            result = result.Where(p => p.CategoryId == selectedCategoryId);

        if (selectedSizes.Any())
            result = result.Where(p =>
                p.ProductSizes.Any(ps =>
                    selectedSizes.Contains(ps.Size.Label) && ps.StockQuantity > 0));

        result = currentSort switch
        {
            "price_asc" => result.OrderBy(p => p.Price),
            "price_desc" => result.OrderByDescending(p => p.Price),
            "rating_desc" => result.OrderByDescending(p => p.AverageRating),
            _ => result
        };

        filteredProducts = result.ToList();
    }

    private void GoToProduct(int id) =>
        Navigation.NavigateTo($"/product/{id}");
}