@using WomenClothingStore.Web.Services
@inject CartService CartService
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">Women's Clothing</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                🏠 Главная
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="catalog">
                🛍️ Каталог товаров
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cart">
                🛒 Корзина
                @if (CartService.GetTotalCount() > 0)
                {
                    <span class="badge bg-danger ms-2 fw-bold">@CartService.GetTotalCount() шт.</span>
                }
            </NavLink>
        </div>
    </nav>
</div>