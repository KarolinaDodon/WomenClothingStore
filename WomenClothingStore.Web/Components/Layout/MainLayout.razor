@inherits LayoutComponentBase
@using WomenClothingStore.Web.Services
@inject CartService CartService

<div class="d-flex">
    <div class="d-flex flex-column flex-shrink-0 p-3 bg-dark" style="width: 280px; min-height: 100vh;">
        <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
            <span class="fs-4">👗 Women's Clothing</span>
        </a>
        <hr class="text-white">
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="/" class="nav-link text-white">
                    🏠 Главная
                </a>
            </li>
            <li>
                <a href="/catalog" class="nav-link text-white">
                    🛍️ Каталог товаров
                </a>
            </li>
            <li>
                <a href="/cart" class="nav-link text-white d-flex align-items-center justify-content-between">
                    <span>🛒 Корзина</span>
                    @if (CartService != null && CartService.GetTotalCount() > 0)
                    {
                        <span class="badge bg-danger rounded-pill fw-bold ms-2">@CartService.GetTotalCount()</span>
                    }
                </a>
            </li>
        </ul>
    </div>

    <div class="flex-grow-1" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
        <div class="container-fluid p-4">
            @Body
        </div>
    </div>
</div>