@page "/cart"
@using WomenClothingStore.Web.Services
@inject CartService CartService
@rendermode InteractiveServer

<h3 class="mb-4 fw-bold text-white">🛒 Ваша корзина</h3>

@if (!CartService.Items.Any())
{
    <div class="card text-center p-5 shadow-sm border-0 bg-light">
        <div class="card-body">
            <div class="fs-1 mb-3">🛍️</div>
            <h5 class="fw-bold text-dark">Ваша корзина пуста</h5>
            <p class="text-muted mb-4">Добавьте товары из каталога, чтобы начать управление покупками.</p>
            <a href="/catalog" class="btn btn-primary px-4">Перейти в каталог</a>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <ul class="list-group list-group-flush">
                    @foreach (var item in CartService.Items)
                    {
                        <li class="list-group-item p-3 border-bottom">
                            <div class="row align-items-center">
                                <div class="col-md-5">
                                    <h6 class="fw-bold text-dark mb-1">@item.Product.Name</h6>
                                    <span class="text-muted small">Цена: @item.Product.Price.ToString("N0") ₽</span>
                                </div>
                                
                                <div class="col-md-4 text-center">
                                    <div class="d-inline-flex align-items-center border rounded bg-white p-1 shadow-sm">
                                        <button type="button" class="btn btn-sm btn-link text-dark fw-bold text-decoration-none px-3" 
                                                @onclick="() => CartService.DecreaseQuantity(item.Product.Id)">-</button>

                                        <span class="px-2 fw-bold text-dark text-center" style="min-width: 45px; display: inline-block;">
                                            @item.Quantity шт
                                        </span>

                                        <button type="button" class="btn btn-sm btn-link text-dark fw-bold text-decoration-none px-3" 
                                                @onclick="() => CartService.AddProduct(item.Product)">+</button>
                                    </div>
                                </div>
                                
                                <div class="col-md-3 text-end">
                                    <div class="fw-bold text-dark mb-2 fs-5">@item.TotalPrice.ToString("N0") ₽</div>
                                    <button type="button" class="btn btn-sm btn-outline-danger border-0 text-decoration-underline" 
                                            @onclick="() => CartService.RemoveProduct(item.Product.Id)">
                                        Удалить
                                    </button>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            </div>
            
            <a href="/catalog" class="btn btn-outline-light fw-bold px-4 shadow-sm">
                ← Вернуться в каталог
            </a>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 bg-light shadow-sm border-0 text-dark">
                <h5 class="fw-bold mb-3">Детали заказа</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Количество вещей:</span>
                    <span class="fw-bold">@CartService.GetTotalCount() шт.</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fs-5 text-muted">Итого:</span>
                    <span class="fs-4 fw-bold text-success">@CartService.GetTotalSum().ToString("N0") ₽</span>
                </div>
            </div>
        </div>
    </div>
}